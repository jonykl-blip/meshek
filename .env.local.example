# Supabase — get these from your project: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
# Note: newer Supabase SDK renamed anon_key → publishable_key (same value, new name)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram Bot — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Webhook secret — set this yourself, then configure it in Vercel and on the Telegram webhook registration
TELEGRAM_WEBHOOK_SECRET=
